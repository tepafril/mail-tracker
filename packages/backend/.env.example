APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#---------------------------------------------------------------------
# SMOH Mail Tracker (custom)
#---------------------------------------------------------------------

# SMOH CRM client (per-tenant base URL + creds live encrypted on the tenant row).
SMOH_TOKEN_TTL=3000
SMOH_EMAIL_TYPE=CRM.Email
SMOH_CONTACT_TYPE=CRM.Contact
SMOH_CONTACT_EMAIL_FIELDS=email,email_business

# Entra (Outlook) OIDC token verification — the client sends an access token for the
# custom API scope api://<app-id>/access_as_user; ENTRA_API_AUDIENCE is that api:// URI.
ENTRA_API_AUDIENCE=
ENTRA_JWKS_URI=https://login.microsoftonline.com/common/discovery/v2.0/keys
ENTRA_ISSUER_TEMPLATE=https://login.microsoftonline.com/{tid}/v2.0

# Microsoft Graph (Phase 2 zero-touch sync for Outlook). App-only client-credentials;
# the app's Mail.Read permission must be admin-consented per client org.
GRAPH_FAKE=false
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Public webhook URLs Graph posts to (on your server, e.g. https://odad.asia/...).
GRAPH_NOTIFICATION_URL=
GRAPH_LIFECYCLE_URL=
GRAPH_SUBSCRIPTION_MINUTES=4320

# Google (Gmail) OIDC — client id the add-on's userIdToken is issued for.
GOOGLE_CLIENT_ID=
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_ISSUERS=https://accounts.google.com,accounts.google.com
# Service account that signs Gmail Pub/Sub push OIDC tokens (Phase 2).
GOOGLE_PUBSUB_SERVICE_ACCOUNT=
# Expected audience of the Pub/Sub push OIDC token (your push endpoint URL). If unset,
# falls back to the request URL — set explicitly when behind a reverse proxy.
GOOGLE_PUBSUB_AUDIENCE=

# First-party client token lifetime in MINUTES (clients refresh via silent NAA + exchange).
SANCTUM_TOKEN_EXPIRATION=720

# Mail tracking behavior.
MAIL_TRACKER_BLACKLIST_DOMAINS=
MAIL_TRACKER_STORE_BODY=true
MAIL_TRACKER_MAX_BODY_LENGTH=100000
# Global default retention (days) for stored email CONTENT; empty = keep indefinitely.
# Per-tenant `content_retention_days` overrides this. Daily job scrubs older rows' PII.
MAIL_TRACKER_RETENTION_DAYS=

# --- LOCAL DEMO MODE (never enable in production) ---
# In-process fake SMOH (no real CRM instance needed) + a dev-login endpoint that mints a
# token for a demo user without a real Entra/Google app. With QUEUE_CONNECTION=sync the
# "Log to CRM" write happens inline so the timeline updates immediately.
SMOH_FAKE=false
MAIL_TRACKER_DEV_AUTH=false

# Local demo seed (php artisan db:seed).
DEMO_TENANT_ID=demo-tenant
DEMO_SMOH_BASE_URL=https://demo.smoh.test
DEMO_SMOH_USERNAME=svc-demo
DEMO_SMOH_PASSWORD=change-me
DEMO_ENTRA_TID=00000000-0000-0000-0000-000000000000
DEMO_USER_EMAIL=rep@demo.test

# Keep the build context small and never ship local state or secrets.
.git
.gitignore
vendor
node_modules
public/build
.env
.env.*
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/app/public/*
database/*.sqlite
tests
phpunit.xml
.phpunit.cache
CHANGELOG.md
README.md

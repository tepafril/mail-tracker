{
  "name": "@smoh/addin-outlook",
  "version": "0.1.0",
  "private": true,
  "description": "SMOH Mail Tracker — Outlook add-in (thin client). Office.js + NAA/MSAL; logs mail to the Laravel backend. See MASTER-PLAN §5.",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "typecheck": "tsc --noEmit",
    "start": "webpack serve --mode development",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.0.0",
    "@smoh/mail-tracker-core": "*"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "copy-webpack-plugin": "^12.0.2",
    "dotenv": "^16.4.5",
    "html-webpack-plugin": "^5.6.3",
    "office-addin-dev-certs": "^1.13.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}

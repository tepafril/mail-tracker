# Build-time config for the Outlook add-in (consumed by webpack DefinePlugin).
# Copy to .env and set for your environment, or export these before `npm run build`.

# Base URL of the Laravel backend (the brain). API calls target ${BACKEND_BASE_URL}/api/v1.
BACKEND_BASE_URL=https://localhost:8000

# Multi-tenant Entra app (client) id registered for this add-in (MASTER-PLAN §5.2).
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Custom API scope to request via NAA. Defaults to api://<ENTRA_CLIENT_ID>/access_as_user.
# NEVER a Graph scope, NEVER the id token (§5.1).
API_SCOPE=

# --- LOCAL DEMO MODE (never enable in production) ---
# Skip MSAL/Entra and sign in via the backend's /auth/dev-login. Requires the backend to
# have MAIL_TRACKER_DEV_AUTH=true. Also set BACKEND_BASE_URL=https://localhost:3000 so
# calls go through the dev-server proxy to the HTTP backend (avoids mixed-content).
DEV_FAKE_AUTH=false

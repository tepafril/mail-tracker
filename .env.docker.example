#######################################################################
# Production env for the Dockerized Mail Tracker backend.
#   cp .env.docker.example .env   then fill in every CHANGE_ME.
# This single file is the source of truth: it configures Laravel AND
# is used by docker-compose for ${...} interpolation (DB creds, etc.).
#######################################################################

APP_NAME="SMOH Mail Tracker"
APP_ENV=production
APP_DEBUG=false
# Generate once with:  docker compose run --rm app php artisan key:generate --show
APP_KEY=CHANGE_ME
APP_URL=https://connector.odad.asia

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Log to the container's stdout so `docker compose logs` is the single log stream.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Database (single-DB multi-tenancy: one normal MySQL database) ---
DB_CONNECTION=mysql
DB_HOST=mysql          # the compose service name
DB_PORT=3306
DB_DATABASE=mail_tracker
DB_USERNAME=mail_tracker
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME   # used only by the mysql container for bootstrap/healthcheck

# --- Redis / queues / cache / sessions (Horizon needs Redis) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis       # the compose service name
REDIS_PORT=6379
REDIS_PASSWORD=null

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (set to a real transport if you send mail; otherwise keep log) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@odad.asia"
MAIL_FROM_NAME="${APP_NAME}"

#---------------------------------------------------------------------
# SMOH Mail Tracker (custom) — fill with your real production values
#---------------------------------------------------------------------
SMOH_TOKEN_TTL=3000
SMOH_EMAIL_TYPE=CRM.Email
SMOH_CONTACT_TYPE=CRM.Contact
SMOH_CONTACT_EMAIL_FIELDS=email,email_business

# Entra (Outlook) OIDC token verification.
# ENTRA_CLIENT_ID  is baked into the add-in build (web image) AND is the app id in manifest.
# ENTRA_API_AUDIENCE is what the backend validates the incoming access token's audience
# against — set it to  api://<ENTRA_CLIENT_ID>.
ENTRA_CLIENT_ID=CHANGE_ME
ENTRA_API_AUDIENCE=api://CHANGE_ME
# Optional custom API scope; blank -> add-in uses api://<client-id>/access_as_user.
API_SCOPE=
ENTRA_JWKS_URI=https://login.microsoftonline.com/common/discovery/v2.0/keys
ENTRA_ISSUER_TEMPLATE=https://login.microsoftonline.com/{tid}/v2.0

# Microsoft Graph (Phase 2 zero-touch sync). Webhook URLs live on this host.
GRAPH_FAKE=false
GRAPH_CLIENT_ID=CHANGE_ME
GRAPH_CLIENT_SECRET=CHANGE_ME
GRAPH_NOTIFICATION_URL=https://connector.odad.asia/api/graph/notifications
GRAPH_LIFECYCLE_URL=https://connector.odad.asia/api/graph/lifecycle
GRAPH_SUBSCRIPTION_MINUTES=4320

# Google (Gmail) OIDC
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_ISSUERS=https://accounts.google.com,accounts.google.com
GOOGLE_PUBSUB_SERVICE_ACCOUNT=
GOOGLE_PUBSUB_AUDIENCE=https://connector.odad.asia/api/gmail/push

# First-party client token lifetime (minutes)
SANCTUM_TOKEN_EXPIRATION=720

# Mail tracking behavior
MAIL_TRACKER_BLACKLIST_DOMAINS=
MAIL_TRACKER_STORE_BODY=true
MAIL_TRACKER_MAX_BODY_LENGTH=100000
MAIL_TRACKER_RETENTION_DAYS=

# Demo mode MUST stay false in production.
SMOH_FAKE=false
MAIL_TRACKER_DEV_AUTH=false
